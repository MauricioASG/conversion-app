{
  "expo": {
    "name": "Gym Converter",
    "slug": "gym-converter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_conversion_app.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_conversion_app.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C1E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mauriciosg.gymconverter",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_conversion_app.png",
        "backgroundColor": "#1C1C1E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
